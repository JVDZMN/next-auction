FROM alpine:3.19

RUN apk add --no-cache curl bash

# Calls the deployed Vercel endpoint every 5 minutes using CRON_SECRET env var.
# Usage: docker run -e CRON_SECRET=xxx -e APP_URL=https://next-auction-iota.vercel.app cron-image
RUN echo '*/5 * * * * curl -s -X GET \
  -H "Authorization: Bearer $CRON_SECRET" \
  "$APP_URL/api/cron/auction-status" \
  >> /var/log/cron.log 2>&1' > /etc/crontabs/root

CMD ["crond", "-f", "-l", "2"]
