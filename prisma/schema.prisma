enum CarStatus {
  active
  completed
  no_bid
  reserve_not_met
  cancelled
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  PRIVATE_USER
  BUSINESS_USER
  ADMIN
}

enum GearType {
  Manual
  Automatic
}


enum FuelType {
  Benzin
  Diesel
  HybridBenzin
  HybridDiesel
  PluginHybrid
  Electric
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  googleId       String?   @unique
  role           Role      @default(PRIVATE_USER)
  cvrNumber      String?   @unique
  skatDisclaimerAccepted Boolean @default(false)
  acceptedAt     DateTime?
  isApprovedByAdmin Boolean @default(false)
  mitIdVerified  Boolean   @default(false)
  sellerVerified Boolean   @default(false)
  dealerDescription String?  @db.Text
  dealerLogoUrl      String?
  dealerCity         String?
  dealerWebsite      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  cars             Car[]
  bids             Bid[]
  notifications    Notification[]
  messagesSent     Message[]      @relation("MessagesSent")
  messagesReceived Message[]      @relation("MessagesReceived")
  likes            Like[]
  savedSearches    SavedSearch[]
  proxyBids        ProxyBid[]
  comments         Comment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Car {
  id                  String        @id @default(cuid())
  ownerId             String
  brand               String
  model               String
  subModel            String?
  variant             String?
  bodyType            String?
  category            String?
  description         String        @db.Text
  specs               String?       @db.Text
  condition           String
  km                  Int
  lastInspectionKm    Int?
  year                Int
  power               Int
  fuel                FuelType?
  gearType            GearType?
  engineSize          Float?
  seats               Int?
  weight              Int?
  licensePlate        String?
  use                 String?
  firstRegistration   DateTime?
  lastInspection      DateTime?
  nextInspection      DateTime?
  streetName          String?
  houseNumber         String?
  zipcode             String?
  city                String?
  latitude            Float?
  longitude           Float?
  images              String[]
  startingPrice       Float
  currentPrice        Float
  reservePrice        Float?
  auctionEndDate      DateTime
  auctionStartDate    DateTime?
  status              CarStatus     @default(active)
  isDraft             Boolean       @default(false)
  winnerBidId         String?       @unique
  vin                 String?
  inspectionReportUrl String?
  serviceHistoryUrls  String[]
  videoUrl            String?
  imagesMeta          Json?
  bidIncrement        Float?
  antiSnipingMinutes  Int           @default(2)
  views               Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bids      Bid[]
  winnerBid Bid?      @relation("WinningBid", fields: [winnerBidId], references: [id])
  messages  Message[]
  likedBy   Like[]
  proxyBids ProxyBid[]
  comments  Comment[]

  @@index([ownerId])
  @@index([status])
  @@index([auctionEndDate])
}

model Like {
  id              String   @id @default(cuid())
  userId          String
  carId           String
  notifyNearClose Boolean  @default(false)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car  Car  @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
  @@index([carId])
  @@index([userId])
}

model ProxyBid {
  id        String   @id @default(cuid())
  carId     String
  bidderId  String
  maxAmount Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  car    Car  @relation(fields: [carId], references: [id], onDelete: Cascade)
  bidder User @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@unique([carId, bidderId])
  @@index([carId])
  @@index([bidderId])
}

model SavedSearch {
  id               String   @id @default(cuid())
  userId           String
  label            String?
  brand            String?
  maxPrice         Float?
  minYear          Int?
  fuel             String?
  notifyNewListing Boolean  @default(true)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}


model Bid {
  id        String   @id @default(cuid())
  carId     String
  bidderId  String
  amount    Float
  createdAt DateTime @default(now())

  car    Car  @relation(fields: [carId], references: [id], onDelete: Cascade)
  bidder User @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  wonCar Car? @relation("WinningBid")

  @@index([carId])
  @@index([bidderId])
  @@index([createdAt])
  @@index([carId, amount(sort: Desc), createdAt(sort: Desc)])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String   @db.Text
  type      String
  carId     String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Message {
  id               String   @id @default(cuid())
  carId            String
  senderId         String
  receiverId       String
  content          String?  @db.Text
  createdAt        DateTime @default(now())
  replyToMessageId String? // for threading/reply

  car      Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  sender   User      @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User      @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  replyTo  Message?  @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies  Message[] @relation("MessageReplies")

  @@index([carId])
  @@index([senderId])
  @@index([receiverId])
  @@index([replyToMessageId])
}

model Comment {
  id        String   @id @default(cuid())
  carId     String
  authorId  String
  body      String   @db.Text
  parentId  String?

  createdAt DateTime @default(now())

  car     Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([carId])
  @@index([authorId])
  @@index([parentId])
}
